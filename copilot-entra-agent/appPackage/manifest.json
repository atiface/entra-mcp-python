{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.24/MicrosoftTeams.schema.json",
    "manifestVersion": "1.24",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Xcede's Entra helpdesk Manager",
        "websiteUrl": "https://www.example.com",
        "privacyUrl": "https://www.example.com/privacy",
        "termsOfUseUrl": "https://www.example.com/termofuse"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "Xcede's Entra agent",
        "full": "Xcede's Entra agent for Copilot"
    },
    "description": {
        "short": "An agent that helps with Entra ID management tasks",
        "full": "A agent that allows helpdesk staff to provide level 2 support for Entra ID issues, such as resetting user MFA, adding users to groups, and looking up user information."
    },
    "accentColor": "#FFFFFF",
    "composeExtensions": [],
    "copilotAgents": {
        "declarativeAgents": [            
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": []
}